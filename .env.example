# Django Configuration
# Copy this file to a new file named '.env' and fill in your actual settings.
# Do NOT commit the '.env' file to your version control system (git).

# Security settings
SECRET_KEY=django-insecure-default-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# Database configuration
# To use Aiven PostgreSQL, get the "Service URI" from console.aiven.io and paste it here.
# Example: postgres://avnadmin:your_password@your-pg-service.aivencloud.com:25313/defaultdb?sslmode=require
DATABASE_URL=postgres://avnadmin:<password>@<host>:<port>/defaultdb?sslmode=require
